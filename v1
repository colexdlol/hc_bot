            elseif Split[1]:lower() == _G.Prefix..'weaken' or Split[1]:lower() == _G.Prefix..'w' then -- Weaken
                if Split[2] ~= nil and _G.Type == 1 and Split[2] ~= '1' then return end
                if Split[2] ~= nil and _G.Type == 2 and Split[2] ~= '2' then return end
                if Split[2] ~= nil and _G.Type == 3 and Split[2] ~= '3' then return end
                if Split[2] ~= nil and _G.Type == 4 and Split[2] ~= '4' then return end

                add_AND_remove_Limbs()
                Evolved = false
                if E_Track ~= nil then
                    E_Track:Stop()
                end
            elseif Split[1]:lower() == _G.Prefix..'monitor' or Split[1]:lower() == _G.Prefix..'m' then -- Monitor
                local Target = getTarget(Split[2]:lower())
        
                if Target then
                    if not table.find(Monitoring, Target) then
                        --print('m: '..Target.Name)
                        table.insert(Monitoring, Target)
                    end
                end
            elseif Split[1]:lower() == _G.Prefix..'unmonitor' or Split[1]:lower() == _G.Prefix..'unm' then -- Unmonitor
                local Target = getTarget(Split[2]:lower())

                if Target then
                    if table.find(Monitoring, Target) then
                        for i,v in ipairs(Monitoring) do
                            if v == Target then
                                table.remove(Monitoring, i)
                            end
                        end
                    end
                end
            elseif Split[1]:lower() == _G.Prefix..'clearm' or Split[1]:lower() == _G.Prefix..'clrm' then -- Clearm
                if Split[2] ~= nil and _G.Type == 1 and Split[2] ~= '1' then return end
                if Split[2] ~= nil and _G.Type == 2 and Split[2] ~= '2' then return end
                if Split[2] ~= nil and _G.Type == 3 and Split[2] ~= '3' then return end
                if Split[2] ~= nil and _G.Type == 4 and Split[2] ~= '4' then return end

                Monitoring = {}
            elseif Split[1]:lower() == _G.Prefix..'reset' or Split[1]:lower() == _G.Prefix..'re' then -- Reset
                if Split[2] ~= nil and _G.Type == 1 and Split[2] ~= '1' then return end
                if Split[2] ~= nil and _G.Type == 2 and Split[2] ~= '2' then return end
                if Split[2] ~= nil and _G.Type == 3 and Split[2] ~= '3' then return end
                if Split[2] ~= nil and _G.Type == 4 and Split[2] ~= '4' then return end

                Player.Character.Humanoid.Health = 0
                replicatesignal(Player.Kill)
            elseif Split[1]:lower() == _G.Prefix..'kick' or Split[1]:lower() == _G.Prefix..'exit' then -- Kick
                if Split[2] ~= nil and _G.Type == 1 and Split[2] ~= '1' then return end
                if Split[2] ~= nil and _G.Type == 2 and Split[2] ~= '2' then return end
                if Split[2] ~= nil and _G.Type == 3 and Split[2] ~= '3' then return end
                if Split[2] ~= nil and _G.Type == 4 and Split[2] ~= '4' then return end

                Player:Kick()
            end
            return
        end)
    end
end


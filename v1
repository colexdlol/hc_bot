local function getTarget(arg)
    if arg == 'me' then
        return Player
    end

    for _, v in pairs(game:GetService('Players'):GetPlayers()) do
        if v.Name:lower() == arg then
            return v
        end
    end

    local input = string.lower(arg)

    local bestPlayer = nil
    local bestPos = math.huge

    for _, v in pairs(game:GetService('Players'):GetPlayers()) do
        local name = string.lower(v.DisplayName)
        local pos = string.find(name, input, 1, true)

        if pos and pos < bestPos and v ~= Player then
            bestPos = pos
            bestPlayer = v
        end
    end

    if bestPlayer then
        return bestPlayer
    end

    for _, v in pairs(game:GetService('Players'):GetPlayers()) do
        local name = string.lower(v.Name)
        local pos = string.find(name, input, 1, true)

        if pos and pos < bestPos and v ~= Player then
            bestPos = pos
            bestPlayer = v
        end
    end

    return bestPlayer
end

local function receiveMessage(Msg, Chatter)

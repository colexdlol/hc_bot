local function CheckKnocked(Target)
	if Target == nil then return true end
    if not Target:FindFirstChild('Humanoid') then return true end
    if Target.Humanoid.Health <= 0 then return true end
    if Target:FindFirstChild('BodyEffects') == nil or Target:FindFirstChild('BodyEffects'):FindFirstChild('K.O') == nil then return false end

	if Target.BodyEffects["K.O"].Value == false and Target:FindFirstChild('GRABBING_CONSTRAINT') == nil then
		return false
	else
		return true
	end
end

local function CheckDeath(Target)
	if Target == nil or not Target:FindFirstChild('Humanoid') then return true end
    if Target.Humanoid.Health <= 0 then return true end
    if Target:FindFirstChild('BodyEffects') == nil then return false end

	if Target.BodyEffects:FindFirstChild('Dead') and Target.BodyEffects["Dead"].Value ~= true then
		return false
	else
		return true
    end
end

